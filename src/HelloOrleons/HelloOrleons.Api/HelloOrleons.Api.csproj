<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.Orleans.Sdk" />
    <PackageReference Include="Microsoft.Orleans.Server" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\HelloOrleons.ServiceDefaults\HelloOrleons.ServiceDefaults.csproj" />
  </ItemGroup>

  <!-- Preserve Orleans and Newtonsoft.Json assemblies that use reflection
       and are not fully AOT/trim-compatible. -->
  <ItemGroup>
    <TrimmerRootAssembly Include="Orleans.Core" />
    <TrimmerRootAssembly Include="Orleans.Runtime" />
    <TrimmerRootAssembly Include="Orleans.Serialization" />
    <TrimmerRootAssembly Include="Orleans.Core.Abstractions" />
    <TrimmerRootAssembly Include="Newtonsoft.Json" />
  </ItemGroup>

</Project>
