<linker>
  <!-- Cosmos DB SDK uses System.Configuration internally via reflection. -->
  <assembly fullname="System.Configuration.ConfigurationManager">
    <type fullname="System.Configuration.ClientConfigurationHost" preserve="all" />
    <type fullname="System.Configuration.ClientConfigurationSystem" preserve="all" />
    <type fullname="System.Configuration.ConfigurationManager" preserve="all" />
    <type fullname="System.Configuration.AppSettingsSection" preserve="all" />
    <type fullname="System.Configuration.Internal.ConfigSystem" preserve="all" />
    <type fullname="System.Configuration.Internal.InternalConfigRoot" preserve="all" />
  </assembly>

  <!-- Cosmos DB SDK ships 4 assemblies. PartitionKeyInternalJsonConverter
       lives in Direct.dll, not Client.dll. All must be preserved. -->
  <assembly fullname="Microsoft.Azure.Cosmos.Client" preserve="all" />
  <assembly fullname="Microsoft.Azure.Cosmos.Direct" preserve="all" />
  <assembly fullname="Microsoft.Azure.Cosmos.Core" preserve="all" />
  <assembly fullname="Microsoft.Azure.Cosmos.Serialization.HybridRow" preserve="all" />

  <assembly fullname="Newtonsoft.Json" preserve="all" />

  <!-- Azure Monitor OpenTelemetry SDK — needed for App Insights telemetry with AOT. -->
  <assembly fullname="Azure.Monitor.OpenTelemetry.Exporter" preserve="all" />
  <assembly fullname="Azure.Monitor.OpenTelemetry.AspNetCore" preserve="all" />
  <assembly fullname="Azure.Monitor.OpenTelemetry.LiveMetrics" preserve="all" />
</linker>
