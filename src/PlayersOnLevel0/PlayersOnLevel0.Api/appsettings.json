{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Azure.Monitor": "Information",
      "OpenTelemetry": "Information",
      "Azure.Monitor.OpenTelemetry.Exporter": "Debug",
      "Azure.Identity": "Warning"
    },
    "Console": {
      "LogLevel": {
        "Default": "Warning"
      }
    }
  },
  "Storage": {
    "Provider": "InMemory"
  },
  "CosmosDb": {
    "Endpoint": "https://localhost:8081",
    "DatabaseName": "playersonlevel0",
    "ContainerName": "players",
    "LeaderboardContainerName": "leaderboard",
    "PartitionKeyPath": "/playerId",
    "InitializeOnStartup": false
  }
}
