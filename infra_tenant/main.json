{
  "$schema": "https://schema.management.azure.com/schemas/2019-08-01/tenantDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "6659850519389259849"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 12,
      "metadata": {
        "description": "Base name (must match the infra deployment)."
      }
    },
    "subscriptionId": {
      "type": "string",
      "metadata": {
        "description": "Azure subscription ID where the resource groups live."
      }
    },
    "regions": {
      "type": "array",
      "defaultValue": [
        {
          "key": "swedencentral",
          "location": "swedencentral"
        },
        {
          "key": "germanywestcentral",
          "location": "germanywestcentral"
        }
      ],
      "metadata": {
        "description": "Region configurations (same shape as infra/main.bicep)."
      }
    }
  },
  "variables": {
    "globalRgId": "[format('/subscriptions/{0}/resourceGroups/rg-{1}-global', parameters('subscriptionId'), parameters('baseName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Management/serviceGroups",
      "apiVersion": "2024-02-01-preview",
      "name": "[format('sg-{0}', parameters('baseName'))]",
      "properties": {
        "displayName": "[format('Always-On {0}', parameters('baseName'))]"
      },
      "tags": {
        "workload": "[parameters('baseName')]",
        "managedBy": "bicep"
      }
    },
    {
      "type": "Microsoft.Relationships/serviceGroupMember",
      "apiVersion": "2023-09-01-preview",
      "name": "[guid(tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName'))), variables('globalRgId'))]",
      "properties": {
        "targetId": "[tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName')))]",
        "sourceId": "[variables('globalRgId')]"
      },
      "dependsOn": [
        "[tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName')))]"
      ]
    },
    {
      "copy": {
        "name": "regionalMembers",
        "count": "[length(parameters('regions'))]"
      },
      "type": "Microsoft.Relationships/serviceGroupMember",
      "apiVersion": "2023-09-01-preview",
      "name": "[guid(tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName'))), format('/subscriptions/{0}/resourceGroups/rg-{1}-{2}', parameters('subscriptionId'), parameters('baseName'), parameters('regions')[copyIndex()].key))]",
      "properties": {
        "targetId": "[tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName')))]",
        "sourceId": "[format('/subscriptions/{0}/resourceGroups/rg-{1}-{2}', parameters('subscriptionId'), parameters('baseName'), parameters('regions')[copyIndex()].key)]"
      },
      "dependsOn": [
        "[tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName')))]"
      ]
    }
  ],
  "outputs": {
    "serviceGroupId": {
      "type": "string",
      "value": "[tenantResourceId('Microsoft.Management/serviceGroups', format('sg-{0}', parameters('baseName')))]"
    },
    "serviceGroupName": {
      "type": "string",
      "value": "[format('sg-{0}', parameters('baseName'))]"
    }
  }
}