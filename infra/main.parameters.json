{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": { "value": "${AZURE_ENV_NAME}" },
    "globalLocation": { "value": "${AZURE_LOCATION}" },
    "acrSku": { "value": "Basic" },
    "frontDoorSku": { "value": "Standard_AzureFrontDoor" },
    "cosmosAutoscaleMaxThroughput": { "value": 1000 },
    "cosmosMode": { "value": "Serverless" },
    "eventHubsSku": { "value": "Standard" },
    "enableLoadTesting": { "value": false },
    "logRetentionDays": { "value": 30 },
    "enableFlux": { "value": false },
    "enableCustomDomain": { "value": false },
    "enablePrivateEndpoints": { "value": true },
    "regions": {
      "value": [
        {
          "key": "swedencentral",
          "location": "swedencentral",
          "stampDefaults": {
            "aksNodeVmSize": "Standard_D2s_v5",
            "aksSystemNodeCount": 1,
            "aksAvailabilityZones": [],
            "aksTier": "Free",
            "aksIngressType": "External",
            "aksUseSpot": true
          },
          "stamps": [{ "key": "001" }]
        },
        {
          "key": "germanywestcentral",
          "location": "germanywestcentral",
          "stampDefaults": {
            "aksNodeVmSize": "Standard_D2s_v5",
            "aksSystemNodeCount": 1,
            "aksAvailabilityZones": [],
            "aksTier": "Free",
            "aksIngressType": "External",
            "aksUseSpot": true
          },
          "stamps": [{ "key": "001" }]
        }
      ]
    }
  }
}
