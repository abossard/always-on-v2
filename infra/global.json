{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "15992170345599338677"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "metadata": {
        "description": "Base name for all resources."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for global resources."
      }
    },
    "acrSku": {
      "type": "string",
      "metadata": {
        "description": "ACR SKU."
      }
    },
    "cosmosAutoscaleMaxThroughput": {
      "type": "int",
      "metadata": {
        "description": "Cosmos DB autoscale max throughput (RU/s)."
      }
    },
    "domainName": {
      "type": "string",
      "metadata": {
        "description": "Domain name for Azure DNS zone."
      }
    },
    "regions": {
      "type": "array",
      "metadata": {
        "description": "Region configurations array."
      }
    },
    "frontDoorSku": {
      "type": "string",
      "defaultValue": "Premium_AzureFrontDoor",
      "allowedValues": [
        "Premium_AzureFrontDoor",
        "Standard_AzureFrontDoor"
      ],
      "metadata": {
        "description": "Front Door SKU. Premium for prod (WAF, Private Link to internal LB). Standard for dev (public origins, lower cost)."
      }
    }
  },
  "variables": {
    "salt": "[substring(uniqueString(subscription().id, parameters('baseName')), 0, 6)]",
    "acrName": "[replace(format('acr{0}{1}', parameters('baseName'), variables('salt')), '-', '')]",
    "cosmosName": "[format('cosmos-{0}-{1}', parameters('baseName'), variables('salt'))]",
    "fdName": "[format('fd-{0}', parameters('baseName'))]",
    "fleetName": "[format('fleet-{0}', parameters('baseName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-acr-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-cosmos-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-fd-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-lt-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-healthmodel-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2025-11-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('acrSku')]"
      },
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-acr-{0}', parameters('baseName'))))]": {}
        }
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled",
        "dataEndpointEnabled": "[equals(parameters('acrSku'), 'Premium')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-acr-{0}', parameters('baseName')))]"
      ]
    },
    {
      "copy": {
        "name": "acrReplications",
        "count": "[length(parameters('regions'))]"
      },
      "condition": "[not(equals(parameters('regions')[copyIndex()].location, parameters('location')))]",
      "type": "Microsoft.ContainerRegistry/registries/replications",
      "apiVersion": "2025-11-01",
      "name": "[format('{0}/{1}', variables('acrName'), parameters('regions')[copyIndex()].location)]",
      "location": "[parameters('regions')[copyIndex()].location]",
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2025-04-15",
      "name": "[variables('cosmosName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-cosmos-{0}', parameters('baseName'))))]": {}
        }
      },
      "properties": {
        "copy": [
          {
            "name": "locations",
            "count": "[length(parameters('regions'))]",
            "input": {
              "locationName": "[parameters('regions')[copyIndex('locations')].location]",
              "failoverPriority": "[copyIndex('locations')]",
              "isZoneRedundant": false
            }
          }
        ],
        "databaseAccountOfferType": "Standard",
        "publicNetworkAccess": "Enabled",
        "enableAutomaticFailover": true,
        "enableMultipleWriteLocations": true,
        "disableLocalAuth": true,
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "backupPolicy": {
          "type": "Continuous",
          "continuousModeProperties": {
            "tier": "Continuous7Days"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-cosmos-{0}', parameters('baseName')))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}', variables('cosmosName'), 'app-db')]",
      "properties": {
        "resource": {
          "id": "app-db"
        },
        "options": {
          "autoscaleSettings": {
            "maxThroughput": "[parameters('cosmosAutoscaleMaxThroughput')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles",
      "apiVersion": "2025-04-15",
      "name": "[variables('fdName')]",
      "location": "global",
      "sku": {
        "name": "[parameters('frontDoorSku')]"
      },
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-fd-{0}', parameters('baseName'))))]": {}
        }
      },
      "properties": {
        "originResponseTimeoutSeconds": 60
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-fd-{0}', parameters('baseName')))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}', variables('fdName'), format('ep-{0}', parameters('baseName')))]",
      "location": "global",
      "properties": {
        "enabledState": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles', variables('fdName'))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/customDomains",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}', variables('fdName'), replace(parameters('domainName'), '.', '-'))]",
      "properties": {
        "hostName": "[parameters('domainName')]",
        "tlsSettings": {
          "certificateType": "ManagedCertificate",
          "minimumTlsVersion": "TLS12"
        },
        "azureDnsZone": {
          "id": "[resourceId('Microsoft.Network/dnsZones', parameters('domainName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/dnsZones', parameters('domainName'))]",
        "[resourceId('Microsoft.Cdn/profiles', variables('fdName'))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/ruleSets",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}', variables('fdName'), 'ApexRedirect')]",
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles', variables('fdName'))]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/ruleSets/rules",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}/{2}', variables('fdName'), 'ApexRedirect', 'RedirectToGitHub')]",
      "properties": {
        "order": 1,
        "actions": [
          {
            "name": "UrlRedirect",
            "parameters": {
              "typeName": "DeliveryRuleUrlRedirectActionParameters",
              "redirectType": "PermanentRedirect",
              "destinationProtocol": "Https",
              "customHostname": "github.com",
              "customPath": "/abossard/always-on-v2"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/ruleSets', variables('fdName'), 'ApexRedirect')]"
      ]
    },
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
      "apiVersion": "2025-04-15",
      "name": "[format('{0}/{1}/{2}', variables('fdName'), format('ep-{0}', parameters('baseName')), 'route-apex-redirect')]",
      "properties": {
        "customDomains": [
          {
            "id": "[resourceId('Microsoft.Cdn/profiles/customDomains', variables('fdName'), replace(parameters('domainName'), '.', '-'))]"
          }
        ],
        "supportedProtocols": [
          "Http",
          "Https"
        ],
        "patternsToMatch": [
          "/*"
        ],
        "httpsRedirect": "Enabled",
        "linkToDefaultDomain": "Disabled",
        "enabledState": "Enabled",
        "ruleSets": [
          {
            "id": "[resourceId('Microsoft.Cdn/profiles/ruleSets', variables('fdName'), 'ApexRedirect')]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/ruleSets', variables('fdName'), 'ApexRedirect')]",
        "[resourceId('Microsoft.Cdn/profiles/customDomains', variables('fdName'), replace(parameters('domainName'), '.', '-'))]",
        "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('fdName'), format('ep-{0}', parameters('baseName')))]"
      ]
    },
    {
      "type": "Microsoft.Network/dnsZones",
      "apiVersion": "2023-07-01-preview",
      "name": "[parameters('domainName')]",
      "location": "global"
    },
    {
      "type": "Microsoft.Network/dnsZones/A",
      "apiVersion": "2023-07-01-preview",
      "name": "[format('{0}/{1}', parameters('domainName'), '@')]",
      "properties": {
        "TTL": 300,
        "targetResource": {
          "id": "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('fdName'), format('ep-{0}', parameters('baseName')))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/dnsZones', parameters('domainName'))]",
        "[resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('fdName'), format('ep-{0}', parameters('baseName')))]"
      ]
    },
    {
      "type": "Microsoft.ContainerService/fleets",
      "apiVersion": "2025-03-01",
      "name": "[variables('fleetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "hubProfile": {
          "dnsPrefix": "[format('fleet-{0}', parameters('baseName'))]"
        }
      }
    },
    {
      "type": "Microsoft.LoadTestService/loadTests",
      "apiVersion": "2024-12-01-preview",
      "name": "[format('lt-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-lt-{0}', parameters('baseName'))))]": {}
        }
      },
      "properties": {},
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-lt-{0}', parameters('baseName')))]"
      ]
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('law-{0}-global', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 90,
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[format('ai-{0}', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-global', parameters('baseName')))]",
        "DisableLocalAuth": true,
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-global', parameters('baseName')))]"
      ]
    }
  ],
  "outputs": {
    "acrId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]"
    },
    "acrName": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2025-11-01').loginServer]"
    },
    "cosmosId": {
      "type": "string",
      "value": "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]"
    },
    "cosmosName": {
      "type": "string",
      "value": "[variables('cosmosName')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2025-04-15').documentEndpoint]"
    },
    "fleetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerService/fleets', variables('fleetName'))]"
    },
    "fleetName": {
      "type": "string",
      "value": "[variables('fleetName')]"
    },
    "frontDoorId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cdn/profiles', variables('fdName'))]"
    },
    "fdEndpointHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Cdn/profiles/afdEndpoints', variables('fdName'), format('ep-{0}', parameters('baseName'))), '2025-04-15').hostName]"
    },
    "loadTestId": {
      "type": "string",
      "value": "[resourceId('Microsoft.LoadTestService/loadTests', format('lt-{0}', parameters('baseName')))]"
    },
    "dnsZoneId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/dnsZones', parameters('domainName'))]"
    },
    "dnsZoneName": {
      "type": "string",
      "value": "[parameters('domainName')]"
    },
    "dnsNameServers": {
      "type": "array",
      "value": "[reference(resourceId('Microsoft.Network/dnsZones', parameters('domainName')), '2023-07-01-preview').nameServers]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', format('ai-{0}', parameters('baseName'))), '2020-02-02').ConnectionString]"
    },
    "appInsightsId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/components', format('ai-{0}', parameters('baseName')))]"
    },
    "healthModelIdentityId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-healthmodel-{0}', parameters('baseName')))]"
    },
    "healthModelIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-healthmodel-{0}', parameters('baseName'))), '2023-01-31').principalId]"
    }
  }
}